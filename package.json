{
  "name": "rocket-timer",
  "version": "1.2.0",
  "productName": "Rocket Timer",
  "description": "The ultimate timer app for events",
  "main": "src/main/main.js",
  "author": {
    "name": "50hz Event Solutions",
    "email": "geral@50-hz.com"
  },
  "license": "GPL-3.0",
  "homepage": "https://github.com/tuneado/Rocket-Timer",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuneado/Rocket-Timer.git"
  },
  "scripts": {
    "start": "electron .",
    "build:css": "tailwindcss -i src/renderer/css/tailwind.css -o src/renderer/dist/tailwind.css",
    "build:js": "node esbuild.config.js",
    "build": "npm run build:css && npm run build:js",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "publish": "npm run build && electron-builder --publish always",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:unit": "vitest run --config vitest.config.mjs",
    "test:unit:watch": "vitest --config vitest.config.mjs",
    "test:unit:coverage": "vitest run --config vitest.config.mjs --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.mjs",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "@tailwindcss/postcss": "^4.1.17",
    "autoprefixer": "^10.4.22",
    "electron": "^38.1.0",
    "electron-builder": "^26.8.1",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.19.0",
    "esbuild-plugin-postcss2": "^0.1.2",
    "eslint": "^9.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "fabric": "^5.5.2",
    "osc": "^2.4.5",
    "preact": "^10.19.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.3"
  },
  "build": {
    "appId": "com.rockettimer",
    "productName": "Rocket Timer",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "tuneado",
      "repo": "Rocket-Timer"
    }
  }
}
