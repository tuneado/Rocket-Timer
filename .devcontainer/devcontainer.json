{
  "name": "Rocket Timer — Linux Test Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "rocket",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },
  "forwardPorts": [6080, 5901, 9999, 8080],
  "portsAttributes": {
    "6080": { "label": "VNC Desktop (open this)", "onAutoForward": "openBrowser" },
    "5901": { "label": "VNC Direct", "onAutoForward": "silent" },
    "9999": { "label": "REST API", "onAutoForward": "silent" },
    "8080": { "label": "WebSocket", "onAutoForward": "silent" }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libgtk-3-0 libnotify4 libnss3 libxss1 libasound2t64 libgbm1 && npm ci && npm run build",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
